<Window x:Class="RestartHistory.Views.HistoryPopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:auto="clr-namespace:System.Windows.Automation;assembly=PresentationCore"
        Title="Restart History" Width="420" SizeToContent="Height" MaxHeight="720"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" Topmost="True"
        UseLayoutRounding="True" SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display" TextOptions.TextRenderingMode="ClearType"
        Deactivated="Window_Deactivated" KeyDown="Window_KeyDown">

    <Window.Resources>
        <SolidColorBrush x:Key="BackgroundBrush" Color="#F0202020"/>
        <SolidColorBrush x:Key="ForegroundBrush" Color="#E0E0E0"/>
        <SolidColorBrush x:Key="SubtleBrush" Color="#888888"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#0078D4"/>
        <SolidColorBrush x:Key="CardBrush" Color="#2A2A2A"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#3A3A3A"/>
        <SolidColorBrush x:Key="HighlightBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="SevOkBrush" Color="#4CAF50"/>
        <SolidColorBrush x:Key="SevWarnBrush" Color="#FFC107"/>
        <SolidColorBrush x:Key="SevErrorBrush" Color="#F44336"/>
        <SolidColorBrush x:Key="SevNoneBrush" Color="#161B22"/>
        <SolidColorBrush x:Key="ScrollThumbBrush" Color="#555555"/>
        <SolidColorBrush x:Key="ScrollTrackBrush" Color="#2A2A2A"/>
        <FontFamily x:Key="FluentIcons">Segoe Fluent Icons, Segoe MDL2 Assets</FontFamily>

        <Style x:Key="SectionHeading" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
        </Style>
        <Style x:Key="ThemedScrollBar" TargetType="ScrollBar">
            <Setter Property="Width" Value="6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="{DynamicResource ScrollTrackBrush}" Width="6">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb><Thumb.Template><ControlTemplate TargetType="Thumb">
                                        <Border Background="{DynamicResource ScrollThumbBrush}" CornerRadius="3" Margin="0,1"/>
                                    </ControlTemplate></Thumb.Template></Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ThemedScrollViewer" TargetType="ScrollViewer">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ScrollContentPresenter Grid.Column="0"/>
                            <ScrollBar Grid.Column="1" x:Name="PART_VerticalScrollBar"
                                       Style="{StaticResource ThemedScrollBar}"
                                       Value="{TemplateBinding VerticalOffset}"
                                       Maximum="{TemplateBinding ScrollableHeight}"
                                       ViewportSize="{TemplateBinding ViewportHeight}"
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{DynamicResource BackgroundBrush}"
            BorderBrush="#44FFFFFF" BorderThickness="1" CornerRadius="10" Margin="10"
            UseLayoutRounding="True" SnapsToDevicePixels="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="16" ShadowDepth="4" Opacity="0.5" Color="Black"/>
        </Border.Effect>

        <Grid Margin="16,14,16,16">
            <!-- ══════════ PAGE: MAIN (original dashboard) ══════════ -->
            <DockPanel x:Name="MainPage">
                <!-- Title bar -->
                <Grid DockPanel.Dock="Top" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="&#xE72C;" FontFamily="{StaticResource FluentIcons}"
                               FontSize="16" Foreground="{StaticResource AccentBrush}"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Grid.Column="1" Text="Restart History" FontSize="15" FontWeight="SemiBold"
                               Foreground="{StaticResource ForegroundBrush}" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0">
                        <Button x:Name="Btn7d" Content="7d" Click="Period_Click" Tag="7"
                                AutomationProperties.Name="Show 7 days"
                                Background="Transparent" Foreground="{StaticResource SubtleBrush}"
                                BorderThickness="0" FontSize="11" Cursor="Hand" Padding="6,4" Margin="0,0,2,0"
                                FocusVisualStyle="{x:Null}"/>
                        <Button x:Name="Btn14d" Content="14d" Click="Period_Click" Tag="14"
                                AutomationProperties.Name="Show 14 days"
                                Background="Transparent" Foreground="{StaticResource SubtleBrush}"
                                BorderThickness="0" FontSize="11" Cursor="Hand" Padding="6,4" Margin="0,0,2,0"
                                FocusVisualStyle="{x:Null}"/>
                        <Button x:Name="Btn30d" Content="30d" Click="Period_Click" Tag="30"
                                AutomationProperties.Name="Show 30 days"
                                Background="Transparent" Foreground="{StaticResource SubtleBrush}"
                                BorderThickness="0" FontSize="11" Cursor="Hand" Padding="6,4"
                                FocusVisualStyle="{x:Null}"/>
                    </StackPanel>
                    <Button Grid.Column="3" Click="Close_Click"
                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                            Padding="0" Width="32" Height="32" VerticalAlignment="Center" ToolTip="Close (Esc)">
                        <TextBlock Text="&#xE711;" FontFamily="{StaticResource FluentIcons}"
                                   FontSize="14" Foreground="{StaticResource SubtleBrush}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                </Grid>

                <!-- AI Summary (at top when available) -->
                <Border x:Name="SummaryPreviewCard" DockPanel.Dock="Top" Visibility="Collapsed"
                        Background="{StaticResource CardBrush}" CornerRadius="8"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        Padding="12,10" Margin="0,0,0,6">
                    <StackPanel>
                        <Grid Margin="0,0,0,6">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE946;" FontFamily="{StaticResource FluentIcons}"
                                           FontSize="12" Foreground="{StaticResource AccentBrush}"
                                           VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <TextBlock Text="Summary" Style="{StaticResource SectionHeading}"/>
                                <TextBlock x:Name="CopilotLabel" Text="Copilot" FontSize="9" Foreground="{StaticResource SubtleBrush}"
                                           VerticalAlignment="Center" Margin="6,0,0,0"/>
                            </StackPanel>
                            <Button x:Name="ShowMoreButton" Click="ShowSummaryPage_Click" HorizontalAlignment="Right" VerticalAlignment="Center"
                                    AutomationProperties.Name="Show detailed summary"
                                    Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="4,2" Visibility="Collapsed">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Show more" FontSize="11" Foreground="{StaticResource AccentBrush}"/>
                                    <TextBlock Text="&#xE76C;" FontFamily="{StaticResource FluentIcons}"
                                               FontSize="10" Foreground="{StaticResource AccentBrush}"
                                               VerticalAlignment="Center" Margin="3,0,0,0"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                        <!-- Loading indicator -->
                        <StackPanel x:Name="LoadingIndicator" Visibility="Collapsed" Margin="0,4,0,8">
                            <TextBlock x:Name="LoadingText" Text="Analyzing restart history..." FontSize="12" 
                                       Foreground="{StaticResource SubtleBrush}" Margin="0,0,0,6"/>
                            <Border Height="4" CornerRadius="2" Background="{StaticResource SevNoneBrush}" ClipToBounds="True">
                                <Border x:Name="LoadingBar" Width="80" Height="4" CornerRadius="2" 
                                        Background="{StaticResource AccentBrush}" HorizontalAlignment="Left"/>
                            </Border>
                        </StackPanel>
                        <!-- Summary text -->
                        <ScrollViewer x:Name="SummaryScrollViewer" Style="{StaticResource ThemedScrollViewer}"
                                      VerticalScrollBarVisibility="Auto" MaxHeight="100">
                            <TextBox x:Name="SummaryPreviewText" TextWrapping="Wrap" IsReadOnly="True"
                                     Background="Transparent" BorderThickness="0" Cursor="Arrow"
                                     FontSize="13" Foreground="{StaticResource ForegroundBrush}" 
                                     Padding="0" IsTabStop="False"/>
                        </ScrollViewer>
                    </StackPanel>
                </Border>

                <!-- Stat tiles -->
                <Grid DockPanel.Dock="Top" Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/><ColumnDefinition Width="6"/>
                        <ColumnDefinition Width="*"/><ColumnDefinition Width="6"/>
                        <ColumnDefinition Width="*"/><ColumnDefinition Width="6"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="{StaticResource CardBrush}" CornerRadius="8"
                            AutomationProperties.Name="Last Boot"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="4,8" Height="78">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="&#xE823;" FontFamily="{StaticResource FluentIcons}" FontSize="18"
                                       Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center" Height="20" Margin="0,0,0,4"/>
                            <TextBlock x:Name="StatBootTime" FontSize="14" FontWeight="Bold"
                                       Foreground="{StaticResource ForegroundBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="Last Boot" FontSize="11" Foreground="{StaticResource SubtleBrush}" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Background="{StaticResource CardBrush}" CornerRadius="8"
                            AutomationProperties.Name="Cause"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="4,8" Height="78" x:Name="CauseTile">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock x:Name="StatCauseIcon" FontFamily="{StaticResource FluentIcons}" FontSize="18"
                                       Foreground="{StaticResource SevOkBrush}" HorizontalAlignment="Center" Height="20" Margin="0,0,0,4"/>
                            <TextBlock x:Name="StatCause" FontSize="14" FontWeight="Bold"
                                       Foreground="{StaticResource ForegroundBrush}" HorizontalAlignment="Center" TextAlignment="Center"/>
                            <TextBlock Text="Cause" FontSize="11" Foreground="{StaticResource SubtleBrush}" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="4" Background="{StaticResource CardBrush}" CornerRadius="8"
                            AutomationProperties.Name="Restarts"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="4,8" Height="78">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="&#xE9D9;" FontFamily="{StaticResource FluentIcons}" FontSize="18"
                                       Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center" Height="20" Margin="0,0,0,4"/>
                            <TextBlock x:Name="StatTotal" FontSize="14" FontWeight="Bold"
                                       Foreground="{StaticResource ForegroundBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="Restarts" FontSize="11" Foreground="{StaticResource SubtleBrush}" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="6" Background="{StaticResource CardBrush}" CornerRadius="8"
                            AutomationProperties.Name="Uptime"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="4,8" Height="78">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="&#xEC92;" FontFamily="{StaticResource FluentIcons}" FontSize="18"
                                       Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center" Height="20" Margin="0,0,0,4"/>
                            <TextBlock x:Name="StatUptime" FontSize="14" FontWeight="Bold"
                                       Foreground="{StaticResource ForegroundBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="Uptime" FontSize="11" Foreground="{StaticResource SubtleBrush}" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Activity -->
                <Border DockPanel.Dock="Top" Background="{StaticResource CardBrush}" CornerRadius="8"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        Padding="12,10" Margin="0,0,0,6">
                    <StackPanel>
                        <Grid Margin="0,0,0,6">
                            <TextBlock Text="Activity" Style="{StaticResource SectionHeading}"/>
                            <TextBlock x:Name="ActivityPeriodLabel" FontSize="10" Foreground="{StaticResource SubtleBrush}"
                                       HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>
                        <StackPanel x:Name="ActivityStrip" Orientation="Horizontal" HorizontalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,6,0,0">
                            <Border Width="10" Height="10" CornerRadius="2" Background="{StaticResource SevNoneBrush}" Margin="0,0,3,0"/>
                            <TextBlock Text="None" FontSize="9" Foreground="{StaticResource SubtleBrush}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <Border Width="10" Height="10" CornerRadius="2" Background="{StaticResource SevOkBrush}" Margin="0,0,3,0"/>
                            <TextBlock Text="Planned" FontSize="9" Foreground="{StaticResource SubtleBrush}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <Border Width="10" Height="10" CornerRadius="2" Background="{StaticResource SevWarnBrush}" Margin="0,0,3,0"/>
                            <TextBlock Text="Unexpected" FontSize="9" Foreground="{StaticResource SubtleBrush}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <Border Width="10" Height="10" CornerRadius="2" Background="{StaticResource SevErrorBrush}" Margin="0,0,3,0"/>
                            <TextBlock Text="Error" FontSize="9" Foreground="{StaticResource SubtleBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Distribution -->
                <Border DockPanel.Dock="Top" Background="{StaticResource CardBrush}" CornerRadius="8"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        Padding="12,10" Margin="0,0,0,6">
                    <StackPanel>
                        <TextBlock Text="Distribution" Style="{StaticResource SectionHeading}" Margin="0,0,0,8"/>
                        <Border CornerRadius="5" Background="{StaticResource SevNoneBrush}" Height="8" ClipToBounds="True" Margin="0,0,0,8">
                            <Canvas x:Name="BreakdownCanvas" ClipToBounds="True"/>
                        </Border>
                        <ItemsControl x:Name="BreakdownLegend">
                            <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- History (fills remaining space) -->
                <Border Background="{StaticResource CardBrush}" CornerRadius="8"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="12,10">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="History" Style="{StaticResource SectionHeading}" Margin="0,0,0,6"/>
                        <ScrollViewer Style="{StaticResource ThemedScrollViewer}"
                                      VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl x:Name="HistoryList" Background="Transparent">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border x:Name="HistoryItemBorder" Background="Transparent" Padding="2,4" CornerRadius="3"
                                                ToolTip="{Binding CauseLabel}"
                                                MouseLeftButtonUp="HistoryItem_Click" Tag="{Binding}">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Cursor" Value="Hand"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#15FFFFFF"/>
                                                        </Trigger>
                                                        <DataTrigger Binding="{Binding SeverityColor}" Value="#4CAF50">
                                                            <Setter Property="Cursor" Value="Arrow"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid Height="24">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="18"/><ColumnDefinition Width="100"/><ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Ellipse Grid.Column="0" Width="8" Height="8" VerticalAlignment="Center" HorizontalAlignment="Center">
                                                    <Ellipse.Style>
                                                        <Style TargetType="Ellipse">
                                                            <Setter Property="Fill" Value="{StaticResource SevOkBrush}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding SeverityColor}" Value="#F44336">
                                                                    <Setter Property="Fill" Value="{StaticResource SevErrorBrush}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding SeverityColor}" Value="#FFC107">
                                                                    <Setter Property="Fill" Value="{StaticResource SevWarnBrush}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Ellipse.Style>
                                                </Ellipse>
                                                <TextBlock Grid.Column="1" VerticalAlignment="Center" Foreground="{StaticResource SubtleBrush}" FontSize="11.5"
                                                           Text="{Binding FormattedTimestamp}"/>
                                                <TextBlock Grid.Column="2" VerticalAlignment="Center" Foreground="{StaticResource ForegroundBrush}"
                                                           FontSize="12" Text="{Binding CauseLabel}"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
            </DockPanel>

            <!-- ══════════ PAGE: SUMMARY (full AI insights) ══════════ -->
            <DockPanel x:Name="SummaryPage" Visibility="Collapsed">
                <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Click="BackToMain_Click"
                            AutomationProperties.Name="Back to dashboard"
                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                            Padding="2,4" VerticalAlignment="Center" Margin="0,0,8,0" ToolTip="Back">
                        <TextBlock Text="&#xE72B;" FontFamily="{StaticResource FluentIcons}"
                                   FontSize="14" Foreground="{StaticResource SubtleBrush}"/>
                    </Button>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock x:Name="SummaryPageIcon" Text="&#xE946;" FontFamily="{StaticResource FluentIcons}"
                                   FontSize="16" Foreground="{StaticResource AccentBrush}"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock x:Name="SummaryPageHeading" Text="" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{StaticResource ForegroundBrush}" VerticalAlignment="Center"/>
                        <TextBlock Text="Copilot" FontSize="10" Foreground="{StaticResource SubtleBrush}"
                                   VerticalAlignment="Center" Margin="8,0,0,0"/>
                    </StackPanel>
                    <Button Grid.Column="3" Click="Close_Click"
                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                            Padding="0" Width="32" Height="32" VerticalAlignment="Center">
                        <TextBlock Text="&#xE711;" FontFamily="{StaticResource FluentIcons}"
                                   FontSize="14" Foreground="{StaticResource SubtleBrush}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                </Grid>

                <Border Background="{StaticResource CardBrush}" CornerRadius="8"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="14,12"
                        VerticalAlignment="Stretch">
                    <Grid>
                        <!-- Loading indicator for history item analysis -->
                        <StackPanel x:Name="SummaryPageLoading" Visibility="Collapsed" VerticalAlignment="Top">
                            <TextBlock x:Name="SummaryPageLoadingText" Text="Analyzing..." FontSize="13" 
                                       Foreground="{StaticResource SubtleBrush}" Margin="0,0,0,6"/>
                            <Border Height="4" CornerRadius="2" Background="{StaticResource SevNoneBrush}" ClipToBounds="True">
                                <Border x:Name="SummaryPageLoadingBar" Width="80" Height="4" CornerRadius="2" 
                                        Background="{StaticResource AccentBrush}" HorizontalAlignment="Left"/>
                            </Border>
                        </StackPanel>
                        <ScrollViewer x:Name="SummaryPageScroll" Style="{StaticResource ThemedScrollViewer}"
                                      VerticalScrollBarVisibility="Auto">
                            <TextBox x:Name="SummaryFullText" TextWrapping="Wrap" IsReadOnly="True"
                                     Background="Transparent" BorderThickness="0" Cursor="Arrow"
                                     FontSize="13" Foreground="{StaticResource ForegroundBrush}"
                                     Padding="0" IsTabStop="False" VerticalAlignment="Top"/>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </DockPanel>
        </Grid>
    </Border>
</Window>
